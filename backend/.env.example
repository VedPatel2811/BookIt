API_PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# Local standalone (backend docker-compose only): use host.docker.internal
# DATABASE_URL=postgresql://myuser:mypassword@host.docker.internal:5432/bookit_db
#
# Local full stack (root docker-compose): use Docker service name
# DATABASE_URL=postgresql://myuser:mypassword@db:5432/bookit_db
#
# Production: use your deployed DB hostname
DATABASE_URL=postgresql://your_user:your_password@your_db_host:5432/bookit_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local standalone: use host.docker.internal
# REDIS_URL=redis://host.docker.internal:6379/0
#
# Local full stack (root docker-compose): use Docker service name
# REDIS_URL=redis://redis:6379/0
#
# Production: use your deployed Redis hostname
REDIS_URL=redis://your_redis_host:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_super_secret_jwt_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 days

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,https://your-frontend-domain.com
